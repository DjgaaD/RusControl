#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

THEME=$(get_query_param "theme")
[ "$THEME" = "dark" ] || THEME="light"
if [ "$REQUEST_METHOD" != "POST" ]; then
    echo "Content-Type: text/html; charset=utf-8"
    echo ""
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Неверный метод запроса</h2><a href='/cgi-bin/devices?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
read -r POST_DATA
MAC=$(normalize_mac "$(post_param "$POST_DATA" "mac")")
CSRF_TOKEN=$(post_param "$POST_DATA" "csrf_token")
if ! verify_csrf_token "$CSRF_TOKEN"; then
    echo "Content-Type: text/html; charset=utf-8"
    echo ""
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Ошибка CSRF проверки</h2><a href='/cgi-bin/devices?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
if ! is_valid_mac "$MAC"; then
    echo "Content-Type: text/html; charset=utf-8"
    echo ""
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Некорректный MAC</h2><a href='/cgi-bin/devices?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
for iface in $(uci show wireless | grep "=wifi-iface" | cut -d= -f1); do
    uci del_list "${iface}.maclist=${MAC}" 2>/dev/null
done
uci commit wireless
RUNTIME_APPLIED=0
for iface in $(hostapd_ifaces); do
    if hostapd_cli -i "$iface" deny_acl DEL_MAC "$MAC" >/dev/null 2>&1; then
        RUNTIME_APPLIED=1
    fi
done
# Fallback: if runtime hostapd control is unavailable, apply via full reload.
[ "$RUNTIME_APPLIED" -eq 1 ] || wifi reload >/dev/null 2>&1
echo "Status: 302 Found"
echo "Location: /cgi-bin/devices?theme=${THEME}"
echo ""
