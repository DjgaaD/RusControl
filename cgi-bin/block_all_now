#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

echo "Content-Type: text/html; charset=utf-8"
echo ""
THEME=$(get_query_param "theme")
[ "$THEME" = "dark" ] || THEME="light"
if [ "$REQUEST_METHOD" != "POST" ]; then
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Неверный метод запроса</h2><a href='/cgi-bin/devices?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
read -r POST_DATA
CSRF_TOKEN=$(post_param "$POST_DATA" "csrf_token")
if ! verify_csrf_token "$CSRF_TOKEN"; then
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Ошибка CSRF проверки</h2><a href='/cgi-bin/devices?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
/www/cgi-bin/wifi_block_all
echo "<html><head><meta charset='utf-8'><meta http-equiv='refresh' content='5;url=/cgi-bin/devices?theme=${THEME}'></head><body>"
echo "<h2>🔒 Все устройства заблокированы</h2><p>Кроме белого списка. WiFi перезагружается...</p></body></html>"
