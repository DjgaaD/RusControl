#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

echo "Content-Type: text/html; charset=utf-8"
echo ""
THEME=$(get_query_param "theme")
[ "$THEME" = "dark" ] || THEME="light"
if [ "$REQUEST_METHOD" = "POST" ]; then
    read -r POST_DATA
    ACTION=$(post_param "$POST_DATA" "action")
    MAC=$(normalize_mac "$(post_param "$POST_DATA" "mac")")
    CSRF_TOKEN=$(post_param "$POST_DATA" "csrf_token")
    if verify_csrf_token "$CSRF_TOKEN"; then
        if [ "$ACTION" = "add" ] && is_valid_mac "$MAC"; then
            echo "$MAC" >> /etc/wifi_whitelist
            sort -u /etc/wifi_whitelist -o /etc/wifi_whitelist
        fi
        if [ "$ACTION" = "del" ] && is_valid_mac "$MAC"; then
            safe_remove_whitelist_mac "$MAC"
        fi
    fi
fi
if [ "$THEME" = "dark" ]; then
    BODY_CLASS="dark"
    BG="#1e1e2e"
else
    BODY_CLASS="light"
    BG="#f5f5f5"
fi
echo "<html><head><title>Белый список</title><meta charset='utf-8'>"
echo "<style>html,body{background:${BG};margin:0}</style>"
echo "<style>"
echo "body{font-family:Arial,sans-serif;padding:10px;margin:0}"
echo "body.dark{background:#1e1e2e;color:#cdd6f4}"
echo "body.light{background:#f5f5f5;color:#333}"
echo "table{border-collapse:collapse;margin:10px 0;box-shadow:0 0 10px rgba(0,0,0,0.1);width:100%}"
echo ".light table{background:white}"
echo ".dark table{background:#313244}"
echo "th,td{padding:8px 10px;border:1px solid #ddd;text-align:left;font-size:0.9em}"
echo ".dark th,.dark td{border:1px solid #45475a}"
echo "th{background:#f2f2f2}"
echo ".dark th{background:#45475a}"
echo ".del-btn{color:white;background:#d00;padding:4px 8px;border-radius:4px;text-decoration:none;font-size:0.85em}"
echo ".add-btn{color:white;background:#090;padding:4px 8px;border-radius:4px;text-decoration:none;font-size:0.85em}"
echo ".light .white-row{background:#e0ffe0;color:#333}"
echo ".dark .white-row{background:#2a4a2e;color:#a6e3a1}"
echo ".action-form{display:inline;margin:0}"
echo ".action-btn{color:white;border:none;padding:4px 8px;border-radius:4px;font-size:0.85em;cursor:pointer}"
echo ".action-btn-add{background:#090}"
echo ".action-btn-del{background:#d00}"
echo "</style></head><body class='${BODY_CLASS}'>"
CSRF_TOKEN=$(ensure_csrf_token)
echo "<h1 style='font-size:1.3em'>⚪ Белый список</h1>"
echo "<p style='font-size:0.9em'>Устройства из белого списка <strong>не блокируются</strong> общими правилами</p>"
echo "<h2 style='font-size:1.1em'>Подключённые</h2>"
echo "<table><tr><th>MAC</th><th>Имя</th><th>IP</th><th>Действие</th></tr>"
while IFS=' ' read -r ts mac ip name rest; do
    [ "$name" = "*" ] && name="—"
    mac_norm=$(normalize_mac "$mac")
    name=$(display_device_name "$mac_norm" "$name")
    safe_mac=$(html_escape "$mac_norm")
    safe_name=$(html_escape "$name")
    safe_ip=$(html_escape "$ip")
    if grep -qix "$mac_norm" /etc/wifi_whitelist 2>/dev/null; then
        echo "<tr class='white-row'><td>$safe_mac</td><td>$safe_name</td><td>$safe_ip</td><td>✅ В списке</td></tr>"
    else
        echo "<tr><td>$safe_mac</td><td>$safe_name</td><td>$safe_ip</td><td><form method='POST' action='/cgi-bin/whitelist?theme=${THEME}' class='action-form'><input type='hidden' name='csrf_token' value='$(html_escape "$CSRF_TOKEN")'><input type='hidden' name='action' value='add'><input type='hidden' name='mac' value='$safe_mac'><button type='submit' class='action-btn action-btn-add'>➕ Добавить</button></form></td></tr>"
    fi
done < /tmp/dhcp.leases
echo "</table>"
echo "<h2 style='font-size:1.1em'>Текущий белый список</h2>"
if [ -s /etc/wifi_whitelist ]; then
    echo "<table><tr><th>MAC</th><th>Имя</th><th>Действие</th></tr>"
    while read mac; do
        [ -z "$mac" ] && continue
        mac_norm=$(normalize_mac "$mac")
        NAME=$(grep -i "$mac_norm" /tmp/dhcp.leases | awk '{print $4}')
        [ -z "$NAME" ] || [ "$NAME" = "*" ] && NAME="—"
        NAME=$(display_device_name "$mac_norm" "$NAME")
        safe_mac=$(html_escape "$mac_norm")
        safe_name=$(html_escape "$NAME")
        echo "<tr><td>$safe_mac</td><td>$safe_name</td><td><form method='POST' action='/cgi-bin/whitelist?theme=${THEME}' class='action-form'><input type='hidden' name='csrf_token' value='$(html_escape "$CSRF_TOKEN")'><input type='hidden' name='action' value='del'><input type='hidden' name='mac' value='$safe_mac'><button type='submit' class='action-btn action-btn-del'>🗑️ Удалить</button></form></td></tr>"
    done < /etc/wifi_whitelist
    echo "</table>"
else
    echo "<p>Белый список пуст</p>"
fi
echo "</body></html>"
