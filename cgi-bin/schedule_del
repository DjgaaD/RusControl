#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

echo "Content-Type: text/html; charset=utf-8"
THEME=$(get_query_param "theme")
[ "$THEME" = "dark" ] || THEME="light"
if [ "$REQUEST_METHOD" != "POST" ]; then
    echo "<html><head><meta charset='utf-8'></head><body><h2>❌ Неверный метод запроса</h2><a href='/cgi-bin/schedule?theme=${THEME}'>← Назад</a></body></html>"
    exit 1
fi
read -r POST_DATA
CSRF_TOKEN=$(post_param "$POST_DATA" "csrf_token")
RULE_ID=$(post_param "$POST_DATA" "rule_id")
if verify_csrf_token "$CSRF_TOKEN" && printf '%s' "$RULE_ID" | grep -Eq '^[0-9-]+$'; then
    safe_remove_sched_rule_id "$RULE_ID"
    /etc/init.d/cron restart
fi
echo "Status: 302 Found"
echo "Location: /cgi-bin/schedule?theme=${THEME}"
echo ""
