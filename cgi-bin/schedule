echo ".add-btn{color:white;background:#0066cc;padding:6px 12px;border-radius:6px;border:none;cursor:pointer;font-size:0.9em}"
echo ".preset-btn{color:white;background:#666;padding:4px 8px;border-radius:6px;border:none;cursor:pointer;font-size:0.8em;margin-right:6px}"
echo ".header{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap}"
echo ".header h1{margin:0;font-size:1.3em}"
echo ".time-box{background:#333;color:#0f0;padding:6px 12px;border-radius:8px;font-family:monospace;font-size:1em}"
echo ".modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:1000;align-items:center;justify-content:center}"
