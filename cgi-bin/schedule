echo ".dark .form-box{background:#313244}"
echo "select,input[type=submit],input[type=text]{padding:6px;margin:3px;border-radius:4px;border:1px solid #ccc}"
echo ".dark select,.dark input[type=text]{background:#45475a;color:#cdd6f4;border:1px solid #585b70}"
echo "input[name=hour_on],input[name=min_on],input[name=hour_off],input[name=min_off]{width:55px;text-align:center}"
echo "input[type=submit]{background:#0066cc;color:white;border:none;cursor:pointer;padding:8px 16px}"
