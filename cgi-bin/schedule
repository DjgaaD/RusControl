#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

echo "Content-Type: text/html; charset=utf-8"
echo ""
THEME=$(get_query_param "theme")
[ "$THEME" = "dark" ] || THEME="light"
METHOD="$REQUEST_METHOD"

shift_days_plus_one() {
    local in_days="$1"
    local out=""
    local d nd
    IFS=','; for d in $in_days; do
        unset IFS
        nd=$(( (d + 1) % 7 ))
        out="${out}${nd},"
    done
    printf '%s' "$out" | sed 's/,$//'
}

day_name() {
    case "$1" in
        0) echo "Вс" ;;
        1) echo "Пн" ;;
        2) echo "Вт" ;;
        3) echo "Ср" ;;
        4) echo "Чт" ;;
        5) echo "Пт" ;;
        6) echo "Сб" ;;
        *) echo "?" ;;
    esac
}

days_to_text() {
    local in_days="$1"
    local out=""
    local d
    IFS=','; for d in $in_days; do
        unset IFS
        out="${out}$(day_name "$d"),"
    done
    printf '%s' "$out" | sed 's/,$//'
}

emit_rule_segments() {
    local in_days="$1"
    local h_on="$2"
    local m_on="$3"
    local h_off="$4"
    local m_off="$5"
    local on_min off_min d nd h_on_n m_on_n h_off_n m_off_n

    h_on_n=$(printf '%s' "$h_on" | sed 's/^0*//')
    m_on_n=$(printf '%s' "$m_on" | sed 's/^0*//')
    h_off_n=$(printf '%s' "$h_off" | sed 's/^0*//')
    m_off_n=$(printf '%s' "$m_off" | sed 's/^0*//')
    [ -n "$h_on_n" ] || h_on_n=0
    [ -n "$m_on_n" ] || m_on_n=0
    [ -n "$h_off_n" ] || h_off_n=0
    [ -n "$m_off_n" ] || m_off_n=0
    on_min=$((h_on_n * 60 + m_on_n))
    off_min=$((h_off_n * 60 + m_off_n))
    IFS=','; for d in $in_days; do
        unset IFS
        if [ "$off_min" -le "$on_min" ]; then
            echo "${d}:${on_min}:1440"
            nd=$(( (d + 1) % 7 ))
            echo "${nd}:0:${off_min}"
        else
            echo "${d}:${on_min}:${off_min}"
        fi
    done
}

has_schedule_conflict() {
    local target="$1"
    local in_days="$2"
    local h_on="$3"
    local m_on="$4"
    local h_off="$5"
    local m_off="$6"
    local exclude_rule_id="$7"
    local new_tmp old_tmp line meta rule_id smac start_days eh_on em_on eh_off em_off

    new_tmp=$(mktemp) || return 1
    old_tmp=$(mktemp) || { rm -f "$new_tmp"; return 1; }
    emit_rule_segments "$in_days" "$h_on" "$m_on" "$h_off" "$m_off" > "$new_tmp"

    if [ -f /etc/crontabs/root ]; then
        grep "#SCHED|.*|B|" /etc/crontabs/root | while read -r line; do
            meta=$(echo "$line" | sed -n 's/.*#SCHED|\(.*\)$/\1/p')
            rule_id=$(echo "$meta" | awk -F'|' '{print $1}')
            [ -n "$exclude_rule_id" ] && [ "$rule_id" = "$exclude_rule_id" ] && continue
            smac=$(echo "$meta" | awk -F'|' '{print $3}')
            [ "$smac" = "$target" ] || continue
            start_days=$(echo "$meta" | awk -F'|' '{print $4}')
            eh_on=$(echo "$meta" | awk -F'|' '{print $6}')
            em_on=$(echo "$meta" | awk -F'|' '{print $7}')
            eh_off=$(echo "$meta" | awk -F'|' '{print $8}')
            em_off=$(echo "$meta" | awk -F'|' '{print $9}')
            emit_rule_segments "$start_days" "$eh_on" "$em_on" "$eh_off" "$em_off"
        done > "$old_tmp"
    fi

    if [ ! -s "$old_tmp" ]; then
        rm -f "$new_tmp" "$old_tmp"
        return 1
    fi

    awk -F: '
        NR==FNR { d[NR]=$1; s[NR]=$2; e[NR]=$3; n=NR; next }
        {
            for (i=1; i<=n; i++) {
                if ($1 == d[i] && s[i] < $3 && $2 < e[i]) {
                    found=1
                }
            }
        }
        END { if (found) exit 1; else exit 0 }
    ' "$new_tmp" "$old_tmp"
    local rc=$?
    rm -f "$new_tmp" "$old_tmp"
    [ "$rc" -ne 0 ]
}

FORM_ERROR=""
FORM_TITLE="Добавить расписание"
FORM_MAC="ALL"
FORM_HOUR_ON="22"
FORM_MIN_ON="00"
FORM_HOUR_OFF="07"
FORM_MIN_OFF="00"
FORM_D_MON=""
FORM_D_TUE=""
FORM_D_WED=""
FORM_D_THU=""
FORM_D_FRI=""
FORM_D_SAT=""
FORM_D_SUN=""
FORM_EDIT_RULE_ID=""
FORM_MODE="repeat"
FORM_DATE_ON=""
FORM_DATE_OFF=""

set_form_days_from_list() {
    local list="$1"
    FORM_D_MON=""; FORM_D_TUE=""; FORM_D_WED=""; FORM_D_THU=""; FORM_D_FRI=""; FORM_D_SAT=""; FORM_D_SUN=""
    echo "$list" | grep -Eq '(^|,)1(,|$)' && FORM_D_MON="checked"
    echo "$list" | grep -Eq '(^|,)2(,|$)' && FORM_D_TUE="checked"
    echo "$list" | grep -Eq '(^|,)3(,|$)' && FORM_D_WED="checked"
    echo "$list" | grep -Eq '(^|,)4(,|$)' && FORM_D_THU="checked"
    echo "$list" | grep -Eq '(^|,)5(,|$)' && FORM_D_FRI="checked"
    echo "$list" | grep -Eq '(^|,)6(,|$)' && FORM_D_SAT="checked"
    echo "$list" | grep -Eq '(^|,)0(,|$)' && FORM_D_SUN="checked"
}

date_time_to_epoch() {
    local d="$1"
    local h="$2"
    local m="$3"
    date -D "%Y-%m-%d %H:%M" -d "${d} ${h}:${m}" +%s 2>/dev/null
}

load_form_from_rule_id() {
    local rule_id="$1"
    local meta
    [ -f /etc/crontabs/root ] || return 1
    meta=$(grep "#SCHED|${rule_id}|B|" /etc/crontabs/root | sed -n '1{s/.*#SCHED|\(.*\)$/\1/p;}')
    [ -n "$meta" ] || return 1
    FORM_EDIT_RULE_ID="$rule_id"
    FORM_TITLE="Редактировать расписание"
    FORM_MAC=$(echo "$meta" | awk -F'|' '{print $3}')
    FORM_HOUR_ON=$(echo "$meta" | awk -F'|' '{print $6}')
    FORM_MIN_ON=$(echo "$meta" | awk -F'|' '{print $7}')
    FORM_HOUR_OFF=$(echo "$meta" | awk -F'|' '{print $8}')
    FORM_MIN_OFF=$(echo "$meta" | awk -F'|' '{print $9}')
    FORM_MODE=$(echo "$meta" | awk -F'|' '{print $10}')
    [ -n "$FORM_MODE" ] || FORM_MODE="repeat"
    if [ "$FORM_MODE" = "once" ]; then
        FORM_DATE_ON=$(echo "$meta" | awk -F'|' '{print $11}')
        FORM_DATE_OFF=$(echo "$meta" | awk -F'|' '{print $12}')
        FORM_D_MON=""; FORM_D_TUE=""; FORM_D_WED=""; FORM_D_THU=""; FORM_D_FRI=""; FORM_D_SAT=""; FORM_D_SUN=""
    else
        set_form_days_from_list "$(echo "$meta" | awk -F'|' '{print $4}')"
        FORM_DATE_ON=""
        FORM_DATE_OFF=""
    fi
    return 0
}

if [ "$METHOD" = "POST" ]; then
    read -r POST_DATA
    ACTION=$(post_param "$POST_DATA" "action")
    CSRF_TOKEN=$(post_param "$POST_DATA" "csrf_token")
    LOAD_RULE_ID=$(post_param "$POST_DATA" "load_rule_id")
    if [ "$ACTION" = "edit_load" ] && verify_csrf_token "$CSRF_TOKEN" && printf '%s' "$LOAD_RULE_ID" | grep -Eq '^[0-9-]+$'; then
        load_form_from_rule_id "$LOAD_RULE_ID" || FORM_ERROR="❌ Не удалось загрузить правило для редактирования"
    fi
    MAC=$(post_param "$POST_DATA" "mac")
    EDIT_RULE_ID=$(post_param "$POST_DATA" "edit_rule_id")
    MODE=$(post_param "$POST_DATA" "mode")
    [ "$MODE" = "once" ] || MODE="repeat"
    FORM_MODE="$MODE"
    FORM_EDIT_RULE_ID="$EDIT_RULE_ID"
    [ "$MAC" = "ALL" ] || MAC=$(normalize_mac "$MAC")
    FORM_MAC="$MAC"
    HOUR_ON=$(post_param "$POST_DATA" "hour_on")
    MIN_ON=$(post_param "$POST_DATA" "min_on")
    HOUR_OFF=$(post_param "$POST_DATA" "hour_off")
    MIN_OFF=$(post_param "$POST_DATA" "min_off")
    HOUR_ON=$(printf '%s' "$HOUR_ON" | sed 's/[^0-9]//g' | cut -c1-2)
    MIN_ON=$(printf '%s' "$MIN_ON" | sed 's/[^0-9]//g' | cut -c1-2)
    HOUR_OFF=$(printf '%s' "$HOUR_OFF" | sed 's/[^0-9]//g' | cut -c1-2)
    MIN_OFF=$(printf '%s' "$MIN_OFF" | sed 's/[^0-9]//g' | cut -c1-2)
    [ -n "$HOUR_ON" ] || HOUR_ON="0"
    [ -n "$MIN_ON" ] || MIN_ON="0"
    [ -n "$HOUR_OFF" ] || HOUR_OFF="0"
    [ -n "$MIN_OFF" ] || MIN_OFF="0"
    FORM_HOUR_ON=$(printf "%02d" "$HOUR_ON")
    FORM_MIN_ON=$(printf "%02d" "$MIN_ON")
    FORM_HOUR_OFF=$(printf "%02d" "$HOUR_OFF")
    FORM_MIN_OFF=$(printf "%02d" "$MIN_OFF")
    DATE_ON=$(post_param "$POST_DATA" "date_on")
    DATE_OFF=$(post_param "$POST_DATA" "date_off")
    FORM_DATE_ON="$DATE_ON"
    FORM_DATE_OFF="$DATE_OFF"
    DAYS=""
    echo "$POST_DATA" | grep -q "d_mon=on" && DAYS="${DAYS}1,"
    echo "$POST_DATA" | grep -q "d_tue=on" && DAYS="${DAYS}2,"
    echo "$POST_DATA" | grep -q "d_wed=on" && DAYS="${DAYS}3,"
    echo "$POST_DATA" | grep -q "d_thu=on" && DAYS="${DAYS}4,"
    echo "$POST_DATA" | grep -q "d_fri=on" && DAYS="${DAYS}5,"
    echo "$POST_DATA" | grep -q "d_sat=on" && DAYS="${DAYS}6,"
    echo "$POST_DATA" | grep -q "d_sun=on" && DAYS="${DAYS}0,"
    DAYS=$(echo "$DAYS" | sed 's/,$//')
    set_form_days_from_list "$DAYS"
    VALID_DAYS=0
    [ "$MODE" = "once" ] || { is_valid_days "$DAYS" && VALID_DAYS=1; }
    [ "$MODE" = "once" ] && VALID_DAYS=1
    if [ "$ACTION" != "edit_load" ] && verify_csrf_token "$CSRF_TOKEN" && is_valid_mac_or_all "$MAC" && is_valid_hour "$HOUR_ON" && is_valid_hour "$HOUR_OFF" && \
       is_valid_minute "$MIN_ON" && is_valid_minute "$MIN_OFF" && [ "$VALID_DAYS" -eq 1 ]; then
        touch /etc/crontabs/root
        if printf '%s' "$EDIT_RULE_ID" | grep -Eq '^[0-9-]+$'; then
            RULE_ID="$EDIT_RULE_ID"
            safe_remove_sched_rule_id "$RULE_ID"
        else
            RULE_ID="$(date +%s)-$$-$(od -An -N2 -tu2 /dev/urandom 2>/dev/null | tr -d ' ' || echo 0)"
        fi
        HOUR_ON_N=$(printf '%s' "$HOUR_ON" | sed 's/^0*//')
        MIN_ON_N=$(printf '%s' "$MIN_ON" | sed 's/^0*//')
        HOUR_OFF_N=$(printf '%s' "$HOUR_OFF" | sed 's/^0*//')
        MIN_OFF_N=$(printf '%s' "$MIN_OFF" | sed 's/^0*//')
        [ -n "$HOUR_ON_N" ] || HOUR_ON_N=0
        [ -n "$MIN_ON_N" ] || MIN_ON_N=0
        [ -n "$HOUR_OFF_N" ] || HOUR_OFF_N=0
        [ -n "$MIN_OFF_N" ] || MIN_OFF_N=0
        ON_MIN_T=$((HOUR_ON_N * 60 + MIN_ON_N))
        OFF_MIN_T=$((HOUR_OFF_N * 60 + MIN_OFF_N))
        OFF_DAYS="$DAYS"
        if [ "$MODE" = "repeat" ] && [ "$OFF_MIN_T" -le "$ON_MIN_T" ]; then
            OFF_DAYS="$(shift_days_plus_one "$DAYS")"
        fi
        CONFLICT=0
        if [ "$MODE" = "repeat" ] && has_schedule_conflict "$MAC" "$DAYS" "$HOUR_ON" "$MIN_ON" "$HOUR_OFF" "$MIN_OFF" "$RULE_ID"; then
            CONFLICT=1
        fi
        if [ "$CONFLICT" -eq 1 ]; then
            FORM_ERROR="❌ Конфликт расписания: новый интервал пересекается с уже существующим для этого устройства"
        else
            if [ "$MODE" = "once" ]; then
                ON_EPOCH=$(date_time_to_epoch "$DATE_ON" "$HOUR_ON" "$MIN_ON")
                OFF_EPOCH=$(date_time_to_epoch "$DATE_OFF" "$HOUR_OFF" "$MIN_OFF")
                if [ -z "$ON_EPOCH" ] || [ -z "$OFF_EPOCH" ] || [ "$OFF_EPOCH" -le "$ON_EPOCH" ]; then
                    FORM_ERROR="❌ Для одноразового правила укажите корректные дату/время и конец позже начала"
                else
                    ON_DAY=$(echo "$DATE_ON" | awk -F- '{print $3+0}')
                    ON_MON=$(echo "$DATE_ON" | awk -F- '{print $2+0}')
                    OFF_DAY=$(echo "$DATE_OFF" | awk -F- '{print $3+0}')
                    OFF_MON=$(echo "$DATE_OFF" | awk -F- '{print $2+0}')
                    if [ "$MAC" = "ALL" ]; then
                        echo "${MIN_ON} ${HOUR_ON} ${ON_DAY} ${ON_MON} * /www/cgi-bin/schedule_once_exec block ALL ${RULE_ID} #SCHED|${RULE_ID}|B|ALL|${DATE_ON}|${DATE_OFF}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|once|${DATE_ON}|${DATE_OFF}" >> /etc/crontabs/root
                        echo "${MIN_OFF} ${HOUR_OFF} ${OFF_DAY} ${OFF_MON} * /www/cgi-bin/schedule_once_exec unblock ALL ${RULE_ID} #SCHED|${RULE_ID}|U|ALL|${DATE_ON}|${DATE_OFF}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|once|${DATE_ON}|${DATE_OFF}" >> /etc/crontabs/root
                    else
                        echo "${MIN_ON} ${HOUR_ON} ${ON_DAY} ${ON_MON} * /www/cgi-bin/schedule_once_exec block ${MAC} ${RULE_ID} #SCHED|${RULE_ID}|B|${MAC}|${DATE_ON}|${DATE_OFF}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|once|${DATE_ON}|${DATE_OFF}" >> /etc/crontabs/root
                        echo "${MIN_OFF} ${HOUR_OFF} ${OFF_DAY} ${OFF_MON} * /www/cgi-bin/schedule_once_exec unblock ${MAC} ${RULE_ID} #SCHED|${RULE_ID}|U|${MAC}|${DATE_ON}|${DATE_OFF}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|once|${DATE_ON}|${DATE_OFF}" >> /etc/crontabs/root
                    fi
                    /etc/init.d/cron restart
                fi
            else
                if [ "$MAC" = "ALL" ]; then
                    echo "${MIN_ON} ${HOUR_ON} * * ${DAYS} /www/cgi-bin/wifi_block_all #SCHED|${RULE_ID}|B|ALL|${DAYS}|${OFF_DAYS}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|repeat" >> /etc/crontabs/root
                    echo "${MIN_OFF} ${HOUR_OFF} * * ${OFF_DAYS} /www/cgi-bin/wifi_unblock_all #SCHED|${RULE_ID}|U|ALL|${DAYS}|${OFF_DAYS}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|repeat" >> /etc/crontabs/root
                else
                    echo "${MIN_ON} ${HOUR_ON} * * ${DAYS} /www/cgi-bin/wifi_block ${MAC} #SCHED|${RULE_ID}|B|${MAC}|${DAYS}|${OFF_DAYS}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|repeat" >> /etc/crontabs/root
                    echo "${MIN_OFF} ${HOUR_OFF} * * ${OFF_DAYS} /www/cgi-bin/wifi_unblock ${MAC} #SCHED|${RULE_ID}|U|${MAC}|${DAYS}|${OFF_DAYS}|${HOUR_ON}|${MIN_ON}|${HOUR_OFF}|${MIN_OFF}|repeat" >> /etc/crontabs/root
                fi
                /etc/init.d/cron restart
            fi
            if [ -z "$FORM_ERROR" ]; then
                FORM_EDIT_RULE_ID=""
                FORM_TITLE="Добавить расписание"
                FORM_MAC="ALL"
                FORM_HOUR_ON="22"
                FORM_MIN_ON="00"
                FORM_HOUR_OFF="07"
                FORM_MIN_OFF="00"
                FORM_D_MON=""; FORM_D_TUE=""; FORM_D_WED=""; FORM_D_THU=""; FORM_D_FRI=""; FORM_D_SAT=""; FORM_D_SUN=""
                FORM_MODE="repeat"
                FORM_DATE_ON=""
                FORM_DATE_OFF=""
            fi
        fi
    fi
fi

if [ "$METHOD" != "POST" ]; then
    EDIT_FROM_QUERY=$(get_query_param "edit_rule_id")
    if printf '%s' "$EDIT_FROM_QUERY" | grep -Eq '^[0-9-]+$'; then
        load_form_from_rule_id "$EDIT_FROM_QUERY" || true
    fi
fi

