    [ "$FORM_D_SUN" = "checked" ] && FORM_DAYS_LIST="${FORM_DAYS_LIST}0,"
    FORM_DAYS_LIST=$(printf '%s' "$FORM_DAYS_LIST" | sed 's/,$//')
    echo "window.onload = function(){ updateClock(); openScheduleModal('add',{ mac:'$(html_escape "$FORM_MAC")', mode:'$(html_escape "$FORM_MODE")', hOn:'$(html_escape "$FORM_HOUR_ON")', mOn:'$(html_escape "$FORM_MIN_ON")', hOff:'$(html_escape "$FORM_HOUR_OFF")', mOff:'$(html_escape "$FORM_MIN_OFF")', dateOn:'$(html_escape "$FORM_DATE_ON")', dateOff:'$(html_escape "$FORM_DATE_OFF")', startDays:'$(html_escape "$FORM_DAYS_LIST")' }); };"
else
    echo "window.onload = function(){ updateClock(); };"
fi
echo "</script>"
echo "<style>"
echo "body{font-family:Arial,sans-serif;padding:10px;margin:0}"
