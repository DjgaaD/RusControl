echo "</style></head><body class='${BODY_CLASS}'>"
echo "<div class='header'>"
echo "<h1>⏰ Расписание блокировки</h1>"
echo "<div class='time-box' id='clock'>загрузка...</div>"
echo "</div>"
CSRF_TOKEN=$(ensure_csrf_token)
echo "<div style='margin:10px 0'><button type='button' class='add-btn' onclick=\"openScheduleModal('add')\">➕ Добавить расписание</button></div>"
echo "<div id='sched-modal' class='modal-overlay' onclick=\"if(event.target===this) closeScheduleModal()\">"
echo "<div class='modal-box'>"
echo "<div class='modal-head'><h3 id='modal-title' style='margin:0'>Добавить расписание</h3><button type='button' class='close-btn' onclick='closeScheduleModal()'>✕</button></div>"
if [ -n "$FORM_ERROR" ]; then
    echo "<p class='err-msg'>$(html_escape "$FORM_ERROR")</p>"
fi
echo "<form method='POST' action='/cgi-bin/schedule?theme=${THEME}'>"
echo "<input type='hidden' name='csrf_token' value='$(html_escape "$CSRF_TOKEN")'>"
echo "<input type='hidden' name='action' value='save'>"
echo "<input type='hidden' id='edit_rule_id' name='edit_rule_id' value=''>"
echo "<p><strong>Тип:</strong><br><select id='mode' name='mode' onchange='toggleModeFields()'><option value='repeat'>Повторяющееся</option><option value='once'>Одноразовое</option></select></p>"
echo "<p><strong>Устройство:</strong><br>"
echo "<select id='mac' name='mac' style='width:100%'>"
echo "<option value='ALL'>🌐 ВСЕ УСТРОЙСТВА (кроме белого списка)</option>"
while IFS=' ' read -r ts mac ip name rest; do
    [ "$name" = "*" ] && name="$mac"
    mac_norm=$(normalize_mac "$mac")
    name=$(display_device_name "$mac_norm" "$name")
    safe_mac=$(html_escape "$mac_norm")
    safe_name=$(html_escape "$name")
    echo "<option value='$safe_mac'>$safe_name ($safe_mac)</option>"
done < /tmp/dhcp.leases
echo "</select></p>"
echo "<p><strong>Блокировать с:</strong> "
echo "<input id='hour_on' type='text' inputmode='numeric' maxlength='2' name='hour_on' value='22' oninput='normalizeTimeInput(this,23)' onblur='finalizeTimeInput(this,0,23)'> ч"
echo "<input id='min_on' type='text' inputmode='numeric' maxlength='2' name='min_on' value='00' oninput='normalizeTimeInput(this,59)' onblur='finalizeTimeInput(this,0,59)'> мин</p>"
echo "<p><strong>Разблокировать в:</strong> "
echo "<input id='hour_off' type='text' inputmode='numeric' maxlength='2' name='hour_off' value='07' oninput='normalizeTimeInput(this,23)' onblur='finalizeTimeInput(this,0,23)'> ч"
echo "<input id='min_off' type='text' inputmode='numeric' maxlength='2' name='min_off' value='00' oninput='normalizeTimeInput(this,59)' onblur='finalizeTimeInput(this,0,59)'> мин</p>"
echo "<div id='once-fields' style='display:none'>"
echo "<p><strong>Дата начала:</strong><br><input id='date_on' type='date' name='date_on' value=''></p>"
echo "<p><strong>Дата конца:</strong><br><input id='date_off' type='date' name='date_off' value=''></p>"
echo "</div>"
echo "<div id='repeat-fields'>"
echo "<p><strong>Дни:</strong><br>"
echo "<span style='display:inline-block;margin-bottom:6px'>"
echo "<button type='button' class='preset-btn' onclick=\"setDaysPreset('all')\">Все дни</button>"
echo "<button type='button' class='preset-btn' onclick=\"setDaysPreset('weekdays')\">Будние</button>"
echo "<button type='button' class='preset-btn' onclick=\"setDaysPreset('weekend')\">Выходные</button>"
echo "</span><br>"
echo "<label><input id='d_mon' type='checkbox' name='d_mon'> Пн</label>"
echo "<label><input id='d_tue' type='checkbox' name='d_tue'> Вт</label>"
echo "<label><input id='d_wed' type='checkbox' name='d_wed'> Ср</label>"
echo "<label><input id='d_thu' type='checkbox' name='d_thu'> Чт</label>"
echo "<label><input id='d_fri' type='checkbox' name='d_fri'> Пт</label>"
echo "<label><input id='d_sat' type='checkbox' name='d_sat'> Сб</label>"
echo "<label><input id='d_sun' type='checkbox' name='d_sun'> Вс</label></p>"
echo "</div>"
echo "<input type='submit' value='💾 Сохранить'>"
echo "</form></div></div>"
echo "<h2 style='font-size:1.1em'>📋 Текущие расписания</h2>"
if [ -f /etc/crontabs/root ] && grep -q "#SCHED|" /etc/crontabs/root; then
    echo "<table><tr><th>Устройство</th><th>Интервал</th><th>Дни/Даты</th><th>Статус</th><th>✏️</th><th>🗑️</th></tr>"
    grep "#SCHED|.*|B|" /etc/crontabs/root | while read line; do
        META=$(echo "$line" | sed -n 's/.*#SCHED|\(.*\)$/\1/p')
        RULE_ID=$(echo "$META" | awk -F'|' '{print $1}')
        SMAC=$(echo "$META" | awk -F'|' '{print $3}')
        START_DAYS=$(echo "$META" | awk -F'|' '{print $4}')
        END_DAYS=$(echo "$META" | awk -F'|' '{print $5}')
        H_ON=$(echo "$META" | awk -F'|' '{print $6}')
        M_ON=$(echo "$META" | awk -F'|' '{print $7}')
        H_OFF=$(echo "$META" | awk -F'|' '{print $8}')
        M_OFF=$(echo "$META" | awk -F'|' '{print $9}')
        MODE=$(echo "$META" | awk -F'|' '{print $10}')
        [ -n "$MODE" ] || MODE="repeat"
        DATE_ON=$(echo "$META" | awk -F'|' '{print $11}')
        DATE_OFF=$(echo "$META" | awk -F'|' '{print $12}')
        if [ "$SMAC" = "ALL" ]; then
            DEV_NAME="🌐 ВСЕ"
        else
            DEV_NAME=$(grep -i "$SMAC" /tmp/dhcp.leases | awk '{print $4}')
            [ -z "$DEV_NAME" ] || [ "$DEV_NAME" = "*" ] && DEV_NAME="$SMAC"
            DEV_NAME=$(display_device_name "$SMAC" "$DEV_NAME")
        fi
        INTERVAL=$(printf "%02d:%02d - %02d:%02d" "$H_ON" "$M_ON" "$H_OFF" "$M_OFF")
        START_DAYS_TEXT=$(days_to_text "$START_DAYS")
        END_DAYS_TEXT=$(days_to_text "$END_DAYS")
        PERIOD_TEXT="$START_DAYS_TEXT → $END_DAYS_TEXT"
        STATUS_TEXT="активно"
        if [ "$MODE" = "once" ]; then
            PERIOD_TEXT="${DATE_ON} → ${DATE_OFF}"
            NOW_EPOCH=$(date +%s)
            OFF_EPOCH=$(date_time_to_epoch "$DATE_OFF" "$H_OFF" "$M_OFF")
            [ -n "$OFF_EPOCH" ] && [ "$NOW_EPOCH" -gt "$OFF_EPOCH" ] && STATUS_TEXT="просрочено"
        fi
        SAFE_DEV_NAME=$(html_escape "$DEV_NAME")
        SAFE_INTERVAL=$(html_escape "$INTERVAL")
        SAFE_PERIOD_TEXT=$(html_escape "$PERIOD_TEXT")
        SAFE_STATUS_TEXT=$(html_escape "$STATUS_TEXT")
        SAFE_RULE_ID=$(html_escape "$RULE_ID")
        printf "<tr><td>%s</td><td>%s</td><td>%s</td><td>%s</td><td><button type='button' class='del-btn' style='background:#555' onclick=\"openScheduleModal('edit',{ruleId:'%s',mac:'%s',mode:'%s',hOn:'%s',mOn:'%s',hOff:'%s',mOff:'%s',dateOn:'%s',dateOff:'%s',startDays:'%s'})\">✏️</button></td><td><form method='POST' action='/cgi-bin/schedule_del?theme=%s' style='display:inline;margin:0'><input type='hidden' name='csrf_token' value='%s'><input type='hidden' name='rule_id' value='%s'><button type='submit' class='del-btn'>🗑️</button></form></td></tr>\n" "$SAFE_DEV_NAME" "$SAFE_INTERVAL" "$SAFE_PERIOD_TEXT" "$SAFE_STATUS_TEXT" "$SAFE_RULE_ID" "$(html_escape "$SMAC")" "$(html_escape "$MODE")" "$(html_escape "$H_ON")" "$(html_escape "$M_ON")" "$(html_escape "$H_OFF")" "$(html_escape "$M_OFF")" "$(html_escape "$DATE_ON")" "$(html_escape "$DATE_OFF")" "$(html_escape "$START_DAYS")" "$THEME" "$(html_escape "$CSRF_TOKEN")" "$SAFE_RULE_ID"
    done
    echo "</table>"
else
    echo "<p>Нет активных расписаний</p>"
fi
echo "</body></html>"
