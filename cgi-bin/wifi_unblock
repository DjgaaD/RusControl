#!/bin/sh
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
. "${SCRIPT_DIR}/lib_ruscontrol.sh"

MAC="$1"
[ "$MAC" = "ALL" ] && exit 1
MAC=$(normalize_mac "$MAC")
is_valid_mac "$MAC" || exit 1
logger -t wifi_schedule "UNBLOCK $MAC"
for iface in $(uci show wireless | grep "=wifi-iface" | cut -d= -f1); do
    uci del_list "${iface}.maclist=${MAC}" 2>/dev/null
done
uci commit wireless
wifi reload >/dev/null 2>&1
for iface in $(hostapd_ifaces); do
    hostapd_cli -i "$iface" deny_acl DEL_MAC "$MAC" 2>/dev/null
    ubus call "hostapd.${iface}" del_client '{"addr":"'"$MAC"'","reason":3,"deauth":true}' 2>/dev/null
done
